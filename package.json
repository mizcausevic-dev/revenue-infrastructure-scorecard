{
  "name": "revenue-infrastructure-scorecard",
  "version": "0.1.0",
  "description": "Board-ready executive intelligence surface for revenue-system integrity, attribution trust, routing risk, reporting posture, and investment-priority scoring. Library + CLI.",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "author": "mizcausevic-dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mizcausevic-dev/revenue-infrastructure-scorecard.git"
  },
  "bugs": {
    "url": "https://github.com/mizcausevic-dev/revenue-infrastructure-scorecard/issues"
  },
  "homepage": "https://github.com/mizcausevic-dev/revenue-infrastructure-scorecard#readme",
  "keywords": [
    "revenue-infrastructure",
    "revops",
    "board-intelligence",
    "executive-intelligence",
    "attribution",
    "pipeline-integrity",
    "risk-scoring",
    "platform-engineering",
    "typescript"
  ],
  "bin": {
    "revenue-infrastructure-scorecard": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app.js",
    "prerender": "tsx scripts/prerender.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "demo": "tsx scripts/run_demo.ts",
    "smoke": "tsx scripts/smoke_check.ts",
    "verify": "npm run lint && npm run typecheck && npm run coverage && npm run build && npm run demo && npm run smoke",
    "render:assets": "powershell -ExecutionPolicy Bypass -File .\\scripts\\render_readme_assets.ps1",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.2",
    "@emnapi/runtime": "^1.11.2",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "supertest": "^7.2.2",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
